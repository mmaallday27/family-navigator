# Copy this file to `.env` and add your key to turn on the live AI Navigator.
# Without it, the app runs fully on the deterministic engine (offline, no key
# needed) — the live path only activates when this is set.
#
#   cp .env.example .env   # then paste your key below and restart `npm run dev`
#
# The key is read server-side by the Vite plugin and NEVER shipped to the browser.
ANTHROPIC_API_KEY=
