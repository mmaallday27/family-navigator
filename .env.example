# Copy this file to `.env` and add your key to turn on the live AI Navigator.
# Without it, the app runs fully on the deterministic engine (offline, no key
# needed) — the live path only activates when this is set.
#
#   cp .env.example .env   # then paste your key below and restart `npm run dev`
#
# The key is read server-side and NEVER shipped to the browser.
ANTHROPIC_API_KEY=

# Where the SQLite database lives. Defaults to server/data/ next to the code.
# In production, point this at a persistent volume so deploys/restarts never
# lose family records — and back that directory up.
# DATA_DIR=/var/lib/family-navigator

# Set in production deploys (enables Secure session cookies, among others).
# NODE_ENV=production
